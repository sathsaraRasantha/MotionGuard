web_application/backend/uploads/

# Extracted injury frames written per-session
web_application/backend/static/frames/

# ── ChromaDB vector store ──────────────────────────────
# Rebuilt automatically from knowledge_base/ on first run
chroma_db/

# ── Frontend build artefacts ───────────────────────────
web_application/frontend/node_modules/
web_application/frontend/dist/
web_application/frontend/.vite/

